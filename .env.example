# Database
DATABASE_URL=postgresql+asyncpg://obsidian_mcp:CHANGE_ME@postgres:5432/obsidian_mcp

# Vault
VAULT_PATH=/obsidian

# Security
SECRET_KEY=CHANGE_ME

# Public hostname Traefik routes to (used by docker-compose labels).
MCP_HOSTNAME=obsidian-mcp.example.com

# Indexer
INDEX_INTERVAL_SECONDS=300

# Embedding provider — `ollama` (default, self-hosted) or `openai` (BYO key).
# Switching providers post-deploy requires `make reset-embeddings`.
EMBEDDING_PROVIDER=ollama

# Vector dimension. Default 1024 matches Ollama+bge-m3 and is also a good
# fit for OpenAI's `text-embedding-3-*` (which honor the `dimensions` param).
EMBEDDING_DIMENSIONS=1024

# --- Ollama settings (used when EMBEDDING_PROVIDER=ollama) ---
OLLAMA_URL=http://ollama:11434
EMBEDDING_MODEL=bge-m3

# --- OpenAI settings (used when EMBEDDING_PROVIDER=openai) ---
# Required when provider=openai; server refuses to start otherwise.
OPENAI_API_KEY=
# Base URL — point at Azure OpenAI or OpenAI-compatible proxies if desired.
OPENAI_BASE_URL=https://api.openai.com/v1
# `text-embedding-3-small` is cheapest; `-large` has ~3x quality at higher cost.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
